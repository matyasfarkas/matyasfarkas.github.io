\newlabel{sec:fiscal_identity}{{7.2}{36}{The Budget-Identity Recursion}{subsection.7.2}{}}
\newlabel{eq:fiscal_gn}{{43}{36}{The Budget-Identity Recursion}{equation.7.43}{}}
\newlabel{eq:fiscal_pb}{{44}{36}{The Budget-Identity Recursion}{equation.7.44}{}}
